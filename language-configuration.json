{
  "comments": { "lineComment": "//" },
  "brackets": [["(", ")"]],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [["(", ")"], ["\"", "\""]],
  "indentationRules": {
    "increaseIndentPattern": "\\($",
    "decreaseIndentPattern": "^\\s*\\)"
  },
  "folding": {
    "markers": {
      "start": "\\(",
      "end": "\\)"
    }
  }
}
